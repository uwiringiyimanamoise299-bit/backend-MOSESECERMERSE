# ─── Server ────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Database (MySQL) ──────────────────────────
# For Render: use an external MySQL provider like PlanetScale, Railway, or Aiven
DB_HOST=your-db-host.example.com
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=montana_shop
DB_PORT=3306

# ─── Auth ──────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here

# ─── Frontend (CORS) ───────────────────────────
# Set this to your deployed frontend URL (e.g. Vercel/Netlify URL)
FRONTEND_URL=https://your-frontend.vercel.app
